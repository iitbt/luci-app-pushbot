msgid "Device Temperature"\nmsgstr "设备温度"\n\nmsgid "DND List for Any Offline"\nmsgstr "任意离线免打扰列表"\n\nmsgid "<br/>May fail due to server stability or frequent connections.<br/>Not recommended if IP can be obtained via interface.<br/>Access randomly from the above list."\nmsgstr "<br/>会因服务器稳定性、连接频繁等原因导致获取失败<br/>如接口可以正常获取 IP，不推荐使用<br/>从以上列表中随机地址访问"\n\nmsgid "Scheduled Push"\nmsgstr "定时推送"\n\nmsgid "If no secondary router and good signal, reduce the above values.<br/>Adjust if frequent disconnects occur due to WiFi sleep.<br/>..╮(╯_╰）╭.."\nmsgstr "若无二级路由设备，信号强度良好，可以减少以上数值<br/>因夜间 wifi 休眠较为玄学，遇到设备频繁推送断开，烦请自行调整参数<br/>..╮(╯_╰）╭.."\n\nmsgid "Lite Mode"\nmsgstr "精简模式"\n\nmsgid "sms: SMS"\nmsgstr "sms：短信"\n\nmsgid "IPv4 API List"\nmsgstr "IPv4 API列表"\n\nmsgid "GitHub Project URL"\nmsgstr "github 项目地址"\n\nmsgid "Test Temperature Command"\nmsgstr "测试温度命令"\n\nmsgid "Push Alert After Exceeding Limit"\nmsgstr "超过次数后推送提醒"\n\nmsgid "DND Start Time"\nmsgstr "免打扰开始时间"\n\nmsgid "PushDeer Key"\nmsgstr "PushDeer Key"\n\nmsgid "Web Login Alert"\nmsgstr "Web 登录提醒"\n\nmsgid "Client List"\nmsgstr "客户端列表"\n\nmsgid "Lite Current Device List"\nmsgstr "精简当前设备列表"\n\nmsgid "Bark Notification Icon"\nmsgstr " Bark 通知图标"\n\nmsgid "DingTalk"\nmsgstr "钉钉"\n\nmsgid "<br/>Special characters may cause sending failure"\nmsgstr "<br/>使用特殊符号可能会造成发送失败"\n\nmsgid "Lite Current Time"\nmsgstr "精简当前时间"\n\nmsgid "DND after all listed devices are offline"\nmsgstr "列表内设备都离线后免打扰"\n\nmsgid "Notify only this interface's devices"\nmsgstr "仅通知此接口设备"\n\nmsgid "Detection Interval"\nmsgstr "检测时间间隔"\n\nmsgid "MAC Filter 2"\nmsgstr "MAC过滤2"\n\nmsgid "Device Offline Timeout (s)"\nmsgstr "设备离线检测超时（s）"\n\nmsgid "IPv6 Change Notification"\nmsgstr "IPv6 变更通知"\n\nmsgid "Get via URL"\nmsgstr "通过URL获取"\n\nmsgid "Third-party webhook: WeCom, DingTalk, Feishu, ServerChan<br>SMS/Email: PushPlus not yet open<br>Channel settings: <a href='http://pushplus.plus/doc/extend/webhook.html' target='_blank'>Click Here</a>"\nmsgstr "第三方webhook：企业微信、钉钉、飞书、server酱<br>sms短信/mail邮箱：PushPlus暂未开放<br>具体channel设定参见：<a href='http://pushplus.plus/doc/extend/webhook.html' target='_blank'>点击这里</a>"\n\nmsgid "Pause pushes during specified hours.<br/>Scheduled pushes are also blocked during DND."\nmsgstr "在指定整点时间段内，暂停推送消息<br/>免打扰时间中，定时推送也会被阻止。"\n\nmsgid "Ignore whitelist login alerts and block actions. Mask notation not supported."\nmsgstr "忽略白名单登陆提醒和拉黑操作，暂不支持掩码位表示"\n\nmsgid "Bark Sound"\nmsgstr "Bark Sound"\n\nmsgid "Bark Level"\nmsgstr "Bark Level"\n\nmsgid "wechat: PushPlus WeChat Official Account"\nmsgstr "wechat：PushPlus微信公众号"\n\nmsgid "Online DND List"\nmsgstr "在线免打扰列表"\n\nmsgid "Device Online Timeout (s)"\nmsgstr "设备上线检测超时（s）"\n\nmsgid "PushDeer"\nmsgstr "PushDeer"\n\nmsgid "mail: Email"\nmsgstr "mail：邮箱"\n\nmsgid "Ensure device can read temperature. Change command in Advanced Settings."\nmsgstr "请确认设备可以获取温度，如需修改命令，请移步高级设置"\n\nmsgid "Self-hosted PushDeer Server"\nmsgstr "自建 PushDeer 服务器"\n\nmsgid "IP Whitelist"\nmsgstr "白名单 IP 列表"\n\nmsgid "Bark Server"\nmsgstr "Bark Server"\n\nmsgid "Enable"\nmsgstr "启用"\n\nmsgid "CPU Load Alert"\nmsgstr "CPU 负载报警"\n\nmsgid "Ignore List"\nmsgstr "忽略列表"\n\nmsgid "PushPlus Custom Webhook"\nmsgstr "PushPlus Custom Webhook"\n\nmsgid "Ensure key login is set, else scripts will fail!<br/>Google how to install sensors on PVE.<br/>Key login example:<br/>opkg update<br/>opkg install openssh-client openssh-keygen<br/>ssh-keygen -t rsa<br/>ssh root@10.0.0.2 \"tee -a ~/.ssh/id_rsa.pub\" < ~/.ssh/id_rsa.pub<br/>ssh root@10.0.0.2 \"cat ~/.ssh/id_rsa.pub >> ~/.ssh/authorized_keys\"<br/>ssh -i ~/.ssh/id_rsa root@10.0.0.2 sensors"\nmsgstr "请确认已经设置好密钥登陆，否则会引起脚本无法运行等错误！<br/>PVE 安装 sensors 命令自行百度<br/>密钥登陆例：<br/>opkg update #更新列表<br/>opkg install openssh-client openssh-keygen #安装openssh客户端<br/>ssh-keygen -t rsa # 生成密钥文件（自行设定密码等信息）<br/>ssh root@10.0.0.2 \\"tee -a ~/.ssh/id_rsa.pub\\" < ~/.ssh/id_rsa.pub # 传送公钥到 PVE<br/>ssh root@10.0.0.2 \\"cat ~/.ssh/id_rsa.pub >> ~/.ssh/authorized_keys\\" # 写入公钥到 PVE<br/>ssh -i ~/.ssh/id_rsa root@10.0.0.2 sensors # 测试温度命令"\n\nmsgid "Scheduled Sending"\nmsgstr "定时发送"\n\nmsgid "Scheduled Reboot"\nmsgstr "定时重启"\n\nmsgid "Avoid daytime DDNS redials. Does not affect disconnect detection.<br/>May be unstable due to nighttime traffic."\nmsgstr "避免白天重拨 ddns 域名等待解析，此功能不影响断网检测<br/>因夜间跑流量问题，该功能可能不稳定"\n\nmsgid "webhook: Third-party Webhook"\nmsgstr "webhook：第三方webhook"\n\nmsgid "Default is 22. Enter custom SSH port if any."\nmsgstr "默认为22，如有自定义，请填写自定义SSH端口"\n\nmsgid "Unit is hours"\nmsgstr "单位为小时"\n\nmsgid "IP Blacklist"\nmsgstr "IP 黑名单列表"\n\nmsgid "Device Online Notification"\nmsgstr "设备上线通知"\n\nmsgid "Disable"\nmsgstr "disable"\n\nmsgid "Feishu WebHook"\nmsgstr "飞书 WebHook"\n\nmsgid "Webhook"\nmsgstr "Webhook"\n\nmsgid "Mode 1 stops all detection, including unattended tasks."\nmsgstr "模式一停止一切检测，包括无人值守。"\n\nmsgid "Global Internet Detection Timeout"\nmsgstr "全球互联检测超时时间"\n\nmsgid "Redial to get Public IP"\nmsgstr "重拨尝试获取公网 ip"\n\nmsgid "PushPlus Custom Webhook"\nmsgstr "PushPlus 自定义Webhook"\n\nmsgid "DND End Time"\nmsgstr "免打扰结束时间"\n\nmsgid "MAC Device Info Database"\nmsgstr "MAC设备信息数据库"\n\nmsgid "Push Content"\nmsgstr "推送内容"\n\nmsgid "Redial"\nmsgstr "重新拨号"\n\nmsgid "PushDeer Server"\nmsgstr "PushDeer Server"\n\nmsgid "Reset traffic data daily at midnight"\nmsgstr "每天零点重置流量数据"\n\nmsgid "Reboot Router"\nmsgstr "重启路由器"\n\nmsgid "Every day at \"..t..\" o'clock"\nmsgstr "每天\"..t..\"点"\n\nmsgid "PushPlus"\nmsgstr "PushPlus"\n\nmsgid "Custom Push"\nmsgstr "自定义推送"\n\nmsgid "Simplified Version"\nmsgstr "简化版"\n\nmsgid "Abnormal Traffic Watchlist"\nmsgstr "异常流量关注列表"\n\nmsgid "Send Manually"\nmsgstr "手动发送"\n\nmsgid "Requires 4.36M raw data. Full ~1.2M, Lite ~250kb.<br/>Do not use network query without proxy."\nmsgstr "需下载 4.36m 原始数据，处理后完整版约 1.2M，简化版约 250kb <br/>若无梯子，请勿使用网络查询"\n\nmsgid "<br/>Device alerts pushed only after 5 mins continuous exceedance.<br/>Max once per hour."\nmsgstr "<br/>设备报警只会在连续五分钟超过设定值时才会推送<br/>而且一个小时内不会再提醒第二次"\n\nmsgid "Do not modify if you don't understand these options."\nmsgstr "如果你不了解这些选项的含义，请不要修改这些选项。"\n\nmsgid "Device Offline Notification"\nmsgstr "设备下线通知"\n\nmsgid "Feishu"\nmsgstr "飞书"\n\nmsgid "Format: AA:AA:AA:AA:AA:AA|BB:BB... Treats multiple MACs as one user.<br/>Pushes only when all devices are offline to avoid dual-wifi spam."\nmsgstr "AA:AA:AA:AA:AA:AA\\|BB:BB:BB:BB:BB:B 可以将多个 MAC 视为同一用户<br/>任一设备在线后不再推送，设备全部离线时才会推送，避免双 wifi 频繁推送"\n\nmsgid "Get via Interface"\nmsgstr "通过接口获取"\n\nmsgid "Web Error Attempt Alert"\nmsgstr "Web 错误尝试提醒"\n\nmsgid "Max Concurrent Threads"\nmsgstr "最大并发进程数"\n\nmsgid "Self-hosted Bark Server"\nmsgstr "自建 Bark 服务器"\n\nmsgid "PushPlus Channel"\nmsgstr "PushPlus Channel"\n\nmsgid "Bark Time-Sensitive Notification"\nmsgstr "Bark 时效性通知"\n\nmsgid "Device Name"\nmsgstr "本设备名称"\n\nmsgid "Count won't reset until reboot. Please add whitelist first."\nmsgstr "直到重启前都不会重置次数，请先添加白名单"\n\nmsgid "Modify settings to auto-repair network"\nmsgstr "修改相关设置项，尝试自动修复网络"\n\nmsgid "Basic Settings"\nmsgstr "基本设置"\n\nmsgid "Default"\nmsgstr "默认"\n\nmsgid "Auto Block"\nmsgstr "自动拉黑"\n\nmsgid "Shorter times give faster responses but use more resources."\nmsgstr "越短的时间时间响应越及时，但会占用更多的系统资源"\n\nmsgid "Full Version"\nmsgstr "完整版"\n\nmsgid "Device Abnormal Traffic Alert (bytes), can append K or M"\nmsgstr "设备异常流量警报（byte），你可以追加 K 或者 M"\n\nmsgid "Send Test"\nmsgstr "发送测试"\n\nmsgid "PVE Virtual Machine"\nmsgstr "PVE 虚拟机"\n\nmsgid "Options 1 and 2 won't modify settings, max 2 attempts.<br/>Option 3 backs up to /usr/bin/pushbot/configbak and restores on failure.<br/>[!! COMPATIBILITY NOT GUARANTEED !!] Do not use if unfamiliar."\nmsgstr "选项 1 选项 2 不会修改设置，并最多尝试 2 次。<br/>选项 3 会将设置项备份于 /usr/bin/pushbot/configbak 目录，并在失败后还原。<br/>【！！无法保证兼容性！！】不熟悉系统设置项，不会救砖请勿使用"\n\nmsgid "Device Abnormal Traffic"\nmsgstr "设备异常流量"\n\nmsgid "PushPlus Topic"\nmsgstr "PushPlus Topic"\n\nmsgid "<br/>Sends every * hours starting from 00:00"\nmsgstr "<br/>从 00:00 开始，每 * 小时发送一次"\n\nmsgid "WebHook"\nmsgstr "WebHook"\n\nmsgid "<br/>Generally select wan. Choose manually for multi-wan."\nmsgstr "<br/>一般选择 wan 接口，多拨环境请自行选择"\n\nmsgid "Redial only during DND"\nmsgstr "仅在免打扰时段重拨"\n\nmsgid "Disable"\nmsgstr "关闭"\n\nmsgid "Enable Logging"\nmsgstr "开启日志"\n\nmsgid "PushPlus Token"\nmsgstr "PushPlus Token"\n\nmsgid "Push Title"\nmsgstr "推送标题"\n\nmsgid "WeCom Bot Webhook"\nmsgstr "企业微信机器人 Webhook"\n\nmsgid "System Status"\nmsgstr "系统运行情况"\n\nmsgid "Offline Detection Count"\nmsgstr "离线检测次数"\n\nmsgid "Send Interval"\nmsgstr "发送间隔"\n\nmsgid "Interval Sending"\nmsgstr "间隔发送"\n\nmsgid "When Network Disconnected"\nmsgstr "网络断开时"\n\nmsgid "Bark Token"\nmsgstr "Bark Token"\n\nmsgid "Device Alias"\nmsgstr "设备别名"\n\nmsgid "Cron Settings"\nmsgstr "定时任务设定"\n\nmsgid "SSH Login Alert"\nmsgstr "SSH 登录提醒"\n\nmsgid "Push Mode"\nmsgstr "推送模式"\n\nmsgid "Bark Self-hosted Server Address"\nmsgstr "Bark 自建服务器地址"\n\nmsgid "DND Time Settings"\nmsgstr "免打扰时段设置"\n\nmsgid "SSH Error Attempt Alert"\nmsgstr "SSH 错误尝试提醒"\n\nmsgid "Mode 2: Silent Mode"\nmsgstr "模式二：静默模式"\n\nmsgid "IPv4 Change Notification"\nmsgstr "IPv4 变更通知"\n\nmsgid "Send"\nmsgstr "发送"\n\nmsgid "SSH Port"\nmsgstr "SSH端口"\n\nmsgid "Download to RAM"\nmsgstr "下载到内存"\n\nmsgid "Ignore Listed Devices"\nmsgstr "忽略列表内设备"\n\nmsgid "Ensure script runs properly to avoid frequent reboots!"\nmsgstr "请确认脚本可以正常运行，否则可能造成频繁重启等错误！"\n\nmsgid "cp: WeCom App"\nmsgstr "cp：企业微信应用"\n\nmsgid "Output Info"\nmsgstr "输出信息"\n\nmsgid "Host Address"\nmsgstr "宿主机地址"\n\nmsgid "CPU Temperature Alert"\nmsgstr "CPU 温度报警"\n\nmsgid "Watchlist"\nmsgstr "关注列表"\n\nmsgid "\"PushBot\" pushes alerts and logs to various platforms.<br>Supports DingTalk, WeCom, PushPlus.<br>Originally by tty228, modified by qinian.<br><br>Report issues here:"\nmsgstr "「全能推送」，英文名「PushBot」，是一款从服务器推送报警信息和日志到各平台的工具。<br>支持钉钉推送，企业微信推送，PushPlus推送。<br>本插件由tty228/luci-app-serverchan创建，然后七年修改为全能推送自用。<br /><br />如果你在使用中遇到问题，请到这里提交："\n\nmsgid "0 is permanent block. Use with caution.<br>If locked out, change your IP to enter LUCI and clear rules."\nmsgstr "0 为永久拉黑，慎用<br>如不幸误操作，请更改设备 IP 进入 LUCI 界面清空规则"\n\nmsgid "WAN Info"\nmsgstr "WAN信息"\n\nmsgid "DND when any listed device is online"\nmsgstr "列表内任意设备在线时免打扰"\n\nmsgid "<br/>Enter MAC and alias separated by '-', e.g.:<br/>XX:XX:XX:XX:XX:XX-MyPhone"\nmsgstr "<br/> 请输入设备 MAC 和设备别名，用“-”隔开，如：<br/> XX:XX:XX:XX:XX:XX-我的手机"\n\nmsgid "Unattended Tasks"\nmsgstr "无人值守任务"\n\nmsgid "Notify only listed devices"\nmsgstr "仅通知列表内设备"\n\nmsgid "Downloads to RAM, re-downloads on reboot.<br/>Download to flash if no proxy."\nmsgstr "懒得做自动更新了，下载到内存中，重启会重新下载 <br/>若无梯子，还是下到机身吧"\n\nmsgid "Bark Notification Icon"\nmsgstr "Bark 通知图标"\n\nmsgid "Push Title Only"\nmsgstr "只推送标题"\n\nmsgid "No Action"\nmsgstr "无操作"\n\nmsgid "PushDeer Self-hosted Server Address"\nmsgstr "PushDeer 自建服务器地址"\n\nmsgid "Abnormal Traffic DND"\nmsgstr "异常流量免打扰"\n\nmsgid "DingTalk Bot Webhook"\nmsgstr "钉钉机器人 Webhook"\n\nmsgid "Enter Device MAC"\nmsgstr "请输入设备 MAC"\n\nmsgid "Executes only when all listed devices are offline.<br/>After 1 hour of DND, watched devices with low traffic (~100kb/m) for 5 mins are considered offline."\nmsgstr "只会在列表中设备都不在线时才会执行<br/>免打扰时段一小时后，关注设备五分钟低流量（约100kb/m）将视为离线"\n\nmsgid "Bark Notification Sound"\nmsgstr "Bark 通知声音"\n\nmsgid "Bark"\nmsgstr "Bark"\n\nmsgid "Avoid special symbols like \", $, !. Result must be a number for temp comparison."\nmsgstr "请尽量避免使用特殊符号，如双引号、$、!等，执行结果需为数字，用于温度对比"\n\nmsgid "MAC Filter"\nmsgstr "MAC过滤"\n\nmsgid "PushBot"\nmsgstr "PushBot"\n\nmsgid "Hint"\nmsgstr "提示"\n\nmsgid "IPv6 API List"\nmsgstr "IPv6 API列表"\n\nmsgid "Bark Icon"\nmsgstr "Bark Icon"\n\nmsgid "PushPlus One-to-Many Push"\nmsgstr "PushPlus 一对多推送"\n\nmsgid "Too short time may cause inaccurate detection"\nmsgstr "过短的时间可能导致检测不准确"\n\nmsgid "Network Query"\nmsgstr "网络查询"\n\nmsgid "Do Not Disturb (DND)"\nmsgstr "免打扰"\n\nmsgid "WeCom"\nmsgstr "企业微信"\n\nmsgid "Mode 1: Script Suspended"\nmsgstr "模式一：脚本挂起"\n\nmsgid "Interface Name"\nmsgstr "接口名称"\n\nmsgid "PushPlus Group Code"\nmsgstr "PushPlus 群组编码"\n\nmsgid "Send Time"\nmsgstr "发送时间"\n\nmsgid "Device name added to push title to identify source."\nmsgstr "在推送信息标题中会标识本设备名称，用于区分推送信息的来源设备"\n\nmsgid "Redial skips IP change notification and delays DDNS update.<br/>Ensure redial gets a public IP, otherwise it just causes drops.<br/>Don't bother if you're on a carrier-grade NAT!"\nmsgstr "重拨时不会推送 ip 变动通知，并会导致你的域名无法及时更新 ip 地址<br/>请确认你可以通过重拨获取公网 ip，否则这不仅徒劳无功还会引起频繁断网<br/>移动等大内网你就别挣扎了！！"\n\n