msgid "Device Temperature"\nmsgstr ""\n\nmsgid "DND List for Any Offline"\nmsgstr ""\n\nmsgid "<br/>May fail due to server stability or frequent connections.<br/>Not recommended if IP can be obtained via interface.<br/>Access randomly from the above list."\nmsgstr ""\n\nmsgid "Scheduled Push"\nmsgstr ""\n\nmsgid "If no secondary router and good signal, reduce the above values.<br/>Adjust if frequent disconnects occur due to WiFi sleep.<br/>..╮(╯_╰）╭.."\nmsgstr ""\n\nmsgid "Lite Mode"\nmsgstr ""\n\nmsgid "sms: SMS"\nmsgstr ""\n\nmsgid "IPv4 API List"\nmsgstr ""\n\nmsgid "GitHub Project URL"\nmsgstr ""\n\nmsgid "Test Temperature Command"\nmsgstr ""\n\nmsgid "Push Alert After Exceeding Limit"\nmsgstr ""\n\nmsgid "DND Start Time"\nmsgstr ""\n\nmsgid "PushDeer Key"\nmsgstr ""\n\nmsgid "Web Login Alert"\nmsgstr ""\n\nmsgid "Client List"\nmsgstr ""\n\nmsgid "Lite Current Device List"\nmsgstr ""\n\nmsgid "Bark Notification Icon"\nmsgstr ""\n\nmsgid "DingTalk"\nmsgstr ""\n\nmsgid "<br/>Special characters may cause sending failure"\nmsgstr ""\n\nmsgid "Lite Current Time"\nmsgstr ""\n\nmsgid "DND after all listed devices are offline"\nmsgstr ""\n\nmsgid "Notify only this interface's devices"\nmsgstr ""\n\nmsgid "Detection Interval"\nmsgstr ""\n\nmsgid "MAC Filter 2"\nmsgstr ""\n\nmsgid "Device Offline Timeout (s)"\nmsgstr ""\n\nmsgid "IPv6 Change Notification"\nmsgstr ""\n\nmsgid "Get via URL"\nmsgstr ""\n\nmsgid "Third-party webhook: WeCom, DingTalk, Feishu, ServerChan<br>SMS/Email: PushPlus not yet open<br>Channel settings: <a href='http://pushplus.plus/doc/extend/webhook.html' target='_blank'>Click Here</a>"\nmsgstr ""\n\nmsgid "Pause pushes during specified hours.<br/>Scheduled pushes are also blocked during DND."\nmsgstr ""\n\nmsgid "Ignore whitelist login alerts and block actions. Mask notation not supported."\nmsgstr ""\n\nmsgid "Bark Sound"\nmsgstr ""\n\nmsgid "Bark Level"\nmsgstr ""\n\nmsgid "wechat: PushPlus WeChat Official Account"\nmsgstr ""\n\nmsgid "Online DND List"\nmsgstr ""\n\nmsgid "Device Online Timeout (s)"\nmsgstr ""\n\nmsgid "PushDeer"\nmsgstr ""\n\nmsgid "mail: Email"\nmsgstr ""\n\nmsgid "Ensure device can read temperature. Change command in Advanced Settings."\nmsgstr ""\n\nmsgid "Self-hosted PushDeer Server"\nmsgstr ""\n\nmsgid "IP Whitelist"\nmsgstr ""\n\nmsgid "Bark Server"\nmsgstr ""\n\nmsgid "Enable"\nmsgstr ""\n\nmsgid "CPU Load Alert"\nmsgstr ""\n\nmsgid "Ignore List"\nmsgstr ""\n\nmsgid "PushPlus Custom Webhook"\nmsgstr ""\n\nmsgid "Ensure key login is set, else scripts will fail!<br/>Google how to install sensors on PVE.<br/>Key login example:<br/>opkg update<br/>opkg install openssh-client openssh-keygen<br/>ssh-keygen -t rsa<br/>ssh root@10.0.0.2 \"tee -a ~/.ssh/id_rsa.pub\" < ~/.ssh/id_rsa.pub<br/>ssh root@10.0.0.2 \"cat ~/.ssh/id_rsa.pub >> ~/.ssh/authorized_keys\"<br/>ssh -i ~/.ssh/id_rsa root@10.0.0.2 sensors"\nmsgstr ""\n\nmsgid "Scheduled Sending"\nmsgstr ""\n\nmsgid "Scheduled Reboot"\nmsgstr ""\n\nmsgid "Avoid daytime DDNS redials. Does not affect disconnect detection.<br/>May be unstable due to nighttime traffic."\nmsgstr ""\n\nmsgid "webhook: Third-party Webhook"\nmsgstr ""\n\nmsgid "Default is 22. Enter custom SSH port if any."\nmsgstr ""\n\nmsgid "Unit is hours"\nmsgstr ""\n\nmsgid "IP Blacklist"\nmsgstr ""\n\nmsgid "Device Online Notification"\nmsgstr ""\n\nmsgid "Disable"\nmsgstr ""\n\nmsgid "Feishu WebHook"\nmsgstr ""\n\nmsgid "Webhook"\nmsgstr ""\n\nmsgid "Mode 1 stops all detection, including unattended tasks."\nmsgstr ""\n\nmsgid "Global Internet Detection Timeout"\nmsgstr ""\n\nmsgid "Redial to get Public IP"\nmsgstr ""\n\nmsgid "PushPlus Custom Webhook"\nmsgstr ""\n\nmsgid "DND End Time"\nmsgstr ""\n\nmsgid "MAC Device Info Database"\nmsgstr ""\n\nmsgid "Push Content"\nmsgstr ""\n\nmsgid "Redial"\nmsgstr ""\n\nmsgid "PushDeer Server"\nmsgstr ""\n\nmsgid "Reset traffic data daily at midnight"\nmsgstr ""\n\nmsgid "Reboot Router"\nmsgstr ""\n\nmsgid "Every day at \"..t..\" o'clock"\nmsgstr ""\n\nmsgid "PushPlus"\nmsgstr ""\n\nmsgid "Custom Push"\nmsgstr ""\n\nmsgid "Simplified Version"\nmsgstr ""\n\nmsgid "Abnormal Traffic Watchlist"\nmsgstr ""\n\nmsgid "Send Manually"\nmsgstr ""\n\nmsgid "Requires 4.36M raw data. Full ~1.2M, Lite ~250kb.<br/>Do not use network query without proxy."\nmsgstr ""\n\nmsgid "<br/>Device alerts pushed only after 5 mins continuous exceedance.<br/>Max once per hour."\nmsgstr ""\n\nmsgid "Do not modify if you don't understand these options."\nmsgstr ""\n\nmsgid "Device Offline Notification"\nmsgstr ""\n\nmsgid "Feishu"\nmsgstr ""\n\nmsgid "Format: AA:AA:AA:AA:AA:AA|BB:BB... Treats multiple MACs as one user.<br/>Pushes only when all devices are offline to avoid dual-wifi spam."\nmsgstr ""\n\nmsgid "Get via Interface"\nmsgstr ""\n\nmsgid "Web Error Attempt Alert"\nmsgstr ""\n\nmsgid "Max Concurrent Threads"\nmsgstr ""\n\nmsgid "Self-hosted Bark Server"\nmsgstr ""\n\nmsgid "PushPlus Channel"\nmsgstr ""\n\nmsgid "Bark Time-Sensitive Notification"\nmsgstr ""\n\nmsgid "Device Name"\nmsgstr ""\n\nmsgid "Count won't reset until reboot. Please add whitelist first."\nmsgstr ""\n\nmsgid "Modify settings to auto-repair network"\nmsgstr ""\n\nmsgid "Basic Settings"\nmsgstr ""\n\nmsgid "Default"\nmsgstr ""\n\nmsgid "Auto Block"\nmsgstr ""\n\nmsgid "Shorter times give faster responses but use more resources."\nmsgstr ""\n\nmsgid "Full Version"\nmsgstr ""\n\nmsgid "Device Abnormal Traffic Alert (bytes), can append K or M"\nmsgstr ""\n\nmsgid "Send Test"\nmsgstr ""\n\nmsgid "PVE Virtual Machine"\nmsgstr ""\n\nmsgid "Options 1 and 2 won't modify settings, max 2 attempts.<br/>Option 3 backs up to /usr/bin/pushbot/configbak and restores on failure.<br/>[!! COMPATIBILITY NOT GUARANTEED !!] Do not use if unfamiliar."\nmsgstr ""\n\nmsgid "Device Abnormal Traffic"\nmsgstr ""\n\nmsgid "PushPlus Topic"\nmsgstr ""\n\nmsgid "<br/>Sends every * hours starting from 00:00"\nmsgstr ""\n\nmsgid "WebHook"\nmsgstr ""\n\nmsgid "<br/>Generally select wan. Choose manually for multi-wan."\nmsgstr ""\n\nmsgid "Redial only during DND"\nmsgstr ""\n\nmsgid "Disable"\nmsgstr ""\n\nmsgid "Enable Logging"\nmsgstr ""\n\nmsgid "PushPlus Token"\nmsgstr ""\n\nmsgid "Push Title"\nmsgstr ""\n\nmsgid "WeCom Bot Webhook"\nmsgstr ""\n\nmsgid "System Status"\nmsgstr ""\n\nmsgid "Offline Detection Count"\nmsgstr ""\n\nmsgid "Send Interval"\nmsgstr ""\n\nmsgid "Interval Sending"\nmsgstr ""\n\nmsgid "When Network Disconnected"\nmsgstr ""\n\nmsgid "Bark Token"\nmsgstr ""\n\nmsgid "Device Alias"\nmsgstr ""\n\nmsgid "Cron Settings"\nmsgstr ""\n\nmsgid "SSH Login Alert"\nmsgstr ""\n\nmsgid "Push Mode"\nmsgstr ""\n\nmsgid "Bark Self-hosted Server Address"\nmsgstr ""\n\nmsgid "DND Time Settings"\nmsgstr ""\n\nmsgid "SSH Error Attempt Alert"\nmsgstr ""\n\nmsgid "Mode 2: Silent Mode"\nmsgstr ""\n\nmsgid "IPv4 Change Notification"\nmsgstr ""\n\nmsgid "Send"\nmsgstr ""\n\nmsgid "SSH Port"\nmsgstr ""\n\nmsgid "Download to RAM"\nmsgstr ""\n\nmsgid "Ignore Listed Devices"\nmsgstr ""\n\nmsgid "Ensure script runs properly to avoid frequent reboots!"\nmsgstr ""\n\nmsgid "cp: WeCom App"\nmsgstr ""\n\nmsgid "Output Info"\nmsgstr ""\n\nmsgid "Host Address"\nmsgstr ""\n\nmsgid "CPU Temperature Alert"\nmsgstr ""\n\nmsgid "Watchlist"\nmsgstr ""\n\nmsgid "\"PushBot\" pushes alerts and logs to various platforms.<br>Supports DingTalk, WeCom, PushPlus.<br>Originally by tty228, modified by qinian.<br><br>Report issues here:"\nmsgstr ""\n\nmsgid "0 is permanent block. Use with caution.<br>If locked out, change your IP to enter LUCI and clear rules."\nmsgstr ""\n\nmsgid "WAN Info"\nmsgstr ""\n\nmsgid "DND when any listed device is online"\nmsgstr ""\n\nmsgid "<br/>Enter MAC and alias separated by '-', e.g.:<br/>XX:XX:XX:XX:XX:XX-MyPhone"\nmsgstr ""\n\nmsgid "Unattended Tasks"\nmsgstr ""\n\nmsgid "Notify only listed devices"\nmsgstr ""\n\nmsgid "Downloads to RAM, re-downloads on reboot.<br/>Download to flash if no proxy."\nmsgstr ""\n\nmsgid "Bark Notification Icon"\nmsgstr ""\n\nmsgid "Push Title Only"\nmsgstr ""\n\nmsgid "No Action"\nmsgstr ""\n\nmsgid "PushDeer Self-hosted Server Address"\nmsgstr ""\n\nmsgid "Abnormal Traffic DND"\nmsgstr ""\n\nmsgid "DingTalk Bot Webhook"\nmsgstr ""\n\nmsgid "Enter Device MAC"\nmsgstr ""\n\nmsgid "Executes only when all listed devices are offline.<br/>After 1 hour of DND, watched devices with low traffic (~100kb/m) for 5 mins are considered offline."\nmsgstr ""\n\nmsgid "Bark Notification Sound"\nmsgstr ""\n\nmsgid "Bark"\nmsgstr ""\n\nmsgid "Avoid special symbols like \", $, !. Result must be a number for temp comparison."\nmsgstr ""\n\nmsgid "MAC Filter"\nmsgstr ""\n\nmsgid "PushBot"\nmsgstr ""\n\nmsgid "Hint"\nmsgstr ""\n\nmsgid "IPv6 API List"\nmsgstr ""\n\nmsgid "Bark Icon"\nmsgstr ""\n\nmsgid "PushPlus One-to-Many Push"\nmsgstr ""\n\nmsgid "Too short time may cause inaccurate detection"\nmsgstr ""\n\nmsgid "Network Query"\nmsgstr ""\n\nmsgid "Do Not Disturb (DND)"\nmsgstr ""\n\nmsgid "WeCom"\nmsgstr ""\n\nmsgid "Mode 1: Script Suspended"\nmsgstr ""\n\nmsgid "Interface Name"\nmsgstr ""\n\nmsgid "PushPlus Group Code"\nmsgstr ""\n\nmsgid "Send Time"\nmsgstr ""\n\nmsgid "Device name added to push title to identify source."\nmsgstr ""\n\nmsgid "Redial skips IP change notification and delays DDNS update.<br/>Ensure redial gets a public IP, otherwise it just causes drops.<br/>Don't bother if you're on a carrier-grade NAT!"\nmsgstr ""\n\n